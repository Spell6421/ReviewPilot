{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/kill-next-dev-before-prisma.ps1",
            "statusMessage": "Checking for Next.js dev server before Prisma…"
          }
        ]
      }
    ]
  }
}
